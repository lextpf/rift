# clangd configuration for Rift.
#
# Why this file exists
# --------------------
# CMakeLists.txt sets CMAKE_EXPORT_COMPILE_COMMANDS ON, but Visual Studio's
# CMake generator silently ignores it - only the Ninja and Makefile
# generators emit compile_commands.json. So if you configured with the
# default `cmake -B build`, build/ has no compile DB, clangd has no per-file
# flags, and most #includes look unresolved even though the project builds.
#
# Two ways to get accurate diagnostics:
#
#   (A) Recommended - generate a side-by-side Ninja build that produces
#       compile_commands.json. clangd auto-discovers it via the
#       CompilationDatabase entry below; the main build/ tree is untouched.
#
#         cmake -B build_clangd -G Ninja `
#               -DCMAKE_TOOLCHAIN_FILE=$env:VCPKG_ROOT/scripts/buildsystems/vcpkg.cmake
#         cmake --build build_clangd --target rift
#
#       (Re-run the configure step whenever you add new source files.)
#
#   (B) Skip the Ninja build. The Add: flags below cover C++23 mode, the
#       project's include paths (both bundled external/ and vcpkg_installed/),
#       and the runtime defines. Navigation and most diagnostics work; some
#       MSVC-specific extensions and per-file defines won't.
#
# If clangd still can't find <Windows.h> / the MSVC STL, point it at cl.exe
# in your editor's clangd args (NOT here - .clangd doesn't accept it):
#
#       --query-driver=C:\\Program*Files*\\Microsoft*Visual*Studio\\**\\cl.exe
#
# Adjust the Vulkan SDK path under Add: if you upgrade the SDK (or rely on
# option A, which picks it up from CMake automatically).

CompileFlags:
  CompilationDatabase: build_clangd

  Add:
    - -std=c++23
    - --target=x86_64-pc-windows-msvc
    - -fms-extensions
    - -fms-compatibility
    - -fdelayed-template-parsing
    - -Wno-microsoft-include
    - -Wno-pragma-once-outside-header
    - -Wno-unknown-attributes

    # Project defines (mirrors CMakeLists.txt and runtime headers)
    - -DUSE_OPENGL
    - -DUSE_FREETYPE
    - -DGLM_ENABLE_EXPERIMENTAL
    - -DNOMINMAX
    - -DWIN32_LEAN_AND_MEAN
    - -D_CRT_SECURE_NO_WARNINGS
    - -D_USE_MATH_DEFINES

    # Project sources
    - -Isrc
    - -Itests

    # Bundled deps (used when not installed via vcpkg)
    - -Iexternal/glad/include
    - -Iexternal/glfw/include
    - -Iexternal/glm
    - -Iexternal/stb
    - -Iexternal/nlohmann

    # vcpkg-installed deps (whichever build tree is configured)
    - -Ibuild/vcpkg_installed/x64-windows/include
    - -Ibuild_clangd/vcpkg_installed/x64-windows/include
    - -Ibuild_tests/vcpkg_installed/x64-windows/include

    # Vulkan SDK (set by the SDK installer to %VULKAN_SDK%; update if the
    # SDK version changes, or rely on the Ninja build to pick it up).
    - -IC:/VulkanSDK/1.4.328.1/Include

  Remove:
    # MSVC-only flags clangd's GCC-style parser chokes on if a
    # compile_commands.json from cl.exe is consumed directly.
    - /EHa
    - /EHsc
    - /MP
    - /MD
    - /MDd
    - /MT
    - /MTd
    - /Gd
    - /Gm-
    - /GS
    - /GR
    - /Gy
    - /Oi
    - /Ot
    - /permissive-
    - /Zc*
    - /ZI
    - /Zi
    - /Z7
    - /JMC
    - /sdl
    - /diagnostics:*
    - /external:*
    - -external:*
    - /Fp*
    - /Fd*
    - /Fo*
    - /FS

Diagnostics:
  # CONTRIBUTING.md prescribes a manual include order, not include-what-you-use,
  # so don't surface include-graph nits.
  UnusedIncludes: None
  MissingIncludes: None
  Suppress:
    - unknown_attribute
    - pp_including_mainfile_in_preamble

Index:
  Background: Build
  StandardLibrary: Yes

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes
  Designators: Yes

Hover:
  ShowAKA: Yes

Completion:
  AllScopes: Yes
