# ============================================================================
# .gitattributes for rift
# ============================================================================

# Default: auto-detect text and normalize to LF on commit.
* text=auto eol=lf

# ----------------------------------------------------------------------------
# C / C++ source
# ----------------------------------------------------------------------------
*.c                     text eol=lf diff=cpp
*.cc                    text eol=lf diff=cpp
*.cpp                   text eol=lf diff=cpp
*.cxx                   text eol=lf diff=cpp
*.h                     text eol=lf diff=cpp
*.hh                    text eol=lf diff=cpp
*.hpp                   text eol=lf diff=cpp
*.hxx                   text eol=lf diff=cpp
*.inl                   text eol=lf diff=cpp
*.ipp                   text eol=lf diff=cpp
*.tcc                   text eol=lf diff=cpp

# ----------------------------------------------------------------------------
# Build system
# ----------------------------------------------------------------------------
CMakeLists.txt          text eol=lf
*.cmake                 text eol=lf
*.cmake.in              text eol=lf
CMakePresets.json       text eol=lf
*.clang-format          text eol=lf
*.clang-tidy            text eol=lf
.clang-format           text eol=lf
.clang-tidy             text eol=lf
.clangd                 text eol=lf
.editorconfig           text eol=lf
*.json                  text eol=lf
*.yml                   text eol=lf
*.yaml                  text eol=lf
*.toml                  text eol=lf
*.ini                   text
*.cfg                   text
*.md                    text diff=markdown
*.xml                   text
*.txt                   text
vcpkg.json              text eol=lf
Doxyfile                text
Doxyfile.in             text
.gitattributes          text eol=lf
.gitignore              text eol=lf

# ----------------------------------------------------------------------------
# Shaders (GLSL / SPIR-V source)
# ----------------------------------------------------------------------------
*.vert                  text
*.frag                  text
*.geom                  text
*.tesc                  text
*.tese                  text
*.comp                  text
*.glsl                  text

# ----------------------------------------------------------------------------
# Scripts
# ----------------------------------------------------------------------------
*.bat                   text eol=crlf
*.cmd                   text eol=crlf
*.ps1                   text eol=crlf
*.psm1                  text eol=crlf
*.sh                    text eol=lf
*.bash                  text eol=lf

# ----------------------------------------------------------------------------
# Generated
# ----------------------------------------------------------------------------
external/**             linguist-vendored
docs/html/**            linguist-generated
build/**                linguist-generated
build-*/**              linguist-generated
*.spv                   binary linguist-generated
shaders/*.vert.spv      binary linguist-generated
shaders/*.frag.spv      binary linguist-generated

# Compiled binaries
*.exe                   binary
*.dll                   binary
*.lib                   binary
*.pdb                   binary
*.exp                   binary
*.obj                   binary
*.o                     binary
*.a                     binary
*.so                    binary
*.so.*                  binary
*.dylib                 binary

# Images / fonts / textures
*.png                   binary
*.jpg                   binary
*.jpeg                  binary
*.gif                   binary
*.bmp                   binary
*.tga                   binary
*.ico                   binary
*.icns                  binary
*.psd                   binary
*.ttf                   binary
*.otf                   binary
*.woff                  binary
*.woff2                 binary
*.wav                   binary
*.ogg                   binary
*.mp3                   binary
*.flac                  binary

# Archives
*.zip                   binary
*.7z                    binary
*.gz                    binary
*.tgz                   binary
*.tar                   binary
*.rar                   binary

# ----------------------------------------------------------------------------
# Linguist tweaks, language picker on GitHub.
# ----------------------------------------------------------------------------
docs/**                 linguist-documentation
shaders/**              linguist-detectable=true
