# Build outputs — keep the empty build/ dir tracked via .gitkeep; build-* stay fully ignored
build/*
!build/.gitkeep
build-*/

# Site folder — keep the empty dir tracked via .gitkeep; ignore any generated contents
site/*
!site/.gitkeep

# Assets
assets/
*.spv

# Generated documentation
docs/html/

# Runtime log file (written by Logger and crash handlers)
rift.project.log

# Cloned dependency repos (fetched by setup.ps1; not vendored like glad/stb/json/ecs)
external/glfw/
external/glm/

# graphify knowledge-graph output
graphify-out/

# Understand-Anything knowledge-graph tool output
.understand-anything/

# Vite dependency cache
.vite/